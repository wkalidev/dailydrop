# Wallet privé pour déployer les contrats (sans 0x)
PRIVATE_KEY=

# Adresses des contrats après déploiement
NEXT_PUBLIC_CELO_CONTRACT_ADDRESS=
NEXT_PUBLIC_BASE_CONTRACT_ADDRESS=
NEXT_PUBLIC_CELO_TESTNET_CONTRACT_ADDRESS=
NEXT_PUBLIC_BASE_TESTNET_CONTRACT_ADDRESS=

# WalletConnect Project ID — obtenir sur https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# URL de ton app déployée (Vercel)
NEXT_PUBLIC_APP_URL=https://dailydrop.vercel.app

# API Keys pour vérification des contrats (optionnel)
CELOSCAN_API_KEY=
BASESCAN_API_KEY=
