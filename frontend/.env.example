# Wallet privé pour déployer les contrats (sans 0x)
PRIVATE_KEY=

# Adresses des contrats après déploiement
NEXT_PUBLIC_CELO_CONTRACT_ADDRESS=
NEXT_PUBLIC_BASE_CONTRACT_ADDRESS=
NEXT_PUBLIC_CELO_TESTNET_CONTRACT_ADDRESS=
NEXT_PUBLIC_BASE_TESTNET_CONTRACT_ADDRESS=

# WalletConnect Project ID — obtenir sur https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# URL de ton app déployée (Vercel)
NEXT_PUBLIC_APP_URL=https://dailydrop.vercel.app

# Relayer auth — shared secret between frontend and relayer API
RELAYER_SECRET=your-random-secret-here
# Exposed to browser — used in CheckInButton to authenticate relayer calls
NEXT_PUBLIC_RELAYER_SECRET=

# API Keys for leaderboard and contract verification
CELOSCAN_API_KEY=
BASESCAN_API_KEY=

# Anthropic API key — powers AI streak coach at /api/agent
ANTHROPIC_API_KEY=
